def kabisat(tahun):
    if (tahun % 400 == 0): #ciri khas kabisat adalah habis dibagi 400, jadi jika bisa dibagi 400 maka true
        return True
    elif (tahun % 100 == 0): #jika tidak habis dibagi 400 namun habis dibagi 100, maka false
        return False
    elif (tahun % 4 == 0): #jika dapat dibagi 4 maka true
        return True
    else: #selain itu, maka false
        return False

inputTahun = int(input("Masukkan tahun: ")) #menginputkan tahun yang diinginkan
hasil = kabisat(inputTahun) #memanggil fungsi kabisat untuk memproses inputan lalu menyimpannya di hasil

if hasil:
    print("Tahun", inputTahun, "adalah tahun kabisat.") #jika hasilnya adalahh kabisat
else:
    print("Tahun", inputTahun, "bukan tahun kabisat.") #jika hasilnya bukan kabisat
